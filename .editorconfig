# EditorConfig — consistent editor defaults across the team.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown: trailing whitespace can be a hard line break — don't strip it.
[*.md]
trim_trailing_whitespace = false

# Don't impose style on vendored/generated or binary-ish files.
[{package-lock.json,*.svg}]
insert_final_newline = unset
