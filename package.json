{
  "name": "alliance-travel",
  "version": "1.0.0",
  "private": true,
  "description": "Alliance Travel — static multilingual (FR/EN/AR) travel site for Cloudflare Pages.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:i18n": "node scripts/verify-i18n.cjs",
    "verify:links": "node scripts/verify-links.cjs",
    "format": "prettier --write \"tests/**/*.mjs\"",
    "format:check": "prettier --check \"tests/**/*.mjs\""
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "vitest": "^2.1.8"
  }
}
